    ]
  },
  {
    "title": "Meeting configurations",
    "internalName": "MM_MeetingConfigurations",
    "kind": "List",
    "template": "GenericList",
    "classification": "Auxiliary",
    "description": "Configuracion funcional, filtros guardados y ajustes por entorno o por usuario.",
    "settings": {
      "enableVersioning": true,
      "majorVersions": 50,
      "enableAttachments": false
    },
    "fields": [
      {
        "displayName": "Configuration key",
        "internalName": "MMConfigurationKey",
        "type": "Text",
        "required": true,
        "indexed": true,
        "maxLength": 128,
        "description": "Clave funcional unica."
      },
      {
        "displayName": "Description",
        "internalName": "MMDescription",
        "type": "Note",
        "required": false,
        "numberOfLines": 6,
        "plainText": true,
        "description": "Descripcion funcional o administrativa."
      },
      {
        "displayName": "Configuration scope",
        "internalName": "MMConfigurationScope",
        "type": "Choice",

          "Title",
          "MMTemplateCode",
          "MMMeetingTypeDefault",
          "MMDurationMinutes",
          "MMDefaultPriority",
          "MMActive"
        ],
        "query": "<OrderBy><FieldRef Name='Title' /></OrderBy>"

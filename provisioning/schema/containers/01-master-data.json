          "Title",
          "MMRoomLookup",
          "MMResourceLookup",
          "MMQuantity",
          "MMIsOperational"
        ],
        "query": "<OrderBy><FieldRef Name='MMRoomLookup' /><FieldRef Name='MMResourceLookup' /></OrderBy>"
      }
    ]
  },
  {
    "title": "Meeting templates",
    "internalName": "MM_MeetingTemplates",
    "kind": "List",
    "template": "GenericList",
    "classification": "Master",
    "description": "Plantillas reutilizables para reuniones estandarizadas.",

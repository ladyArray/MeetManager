        "required": true,
        "indexed": true,
        "lookupList": "MM_MeetingRooms",
        "lookupField": "Title",
        "description": "Sala a la que se asigna el recurso."
      },
      {
        "displayName": "Resource",
        "internalName": "MMResourceLookup",
        "type": "Lookup",
        "required": true,
        "indexed": true,
        "lookupList": "MM_RoomResources",
        "lookupField": "Title",
        "description": "Recurso asignado."
      },
      {
        "displayName": "Quantity",
        "internalName": "MMQuantity",
        "type": "Number",
        "required": true,
        "defaultValue": 1,
        "minValue": 0,
        "decimals": 0,
        "description": "Cantidad disponible."
      },
      {
        "displayName": "Is operational",
        "internalName": "MMIsOperational",
        "type": "Boolean",
        "required": true,
        "indexed": true,
        "defaultValue": true,
        "description": "Estado operativo del recurso en la sala."
      },
      {
        "displayName": "Inventory code",
        "internalName": "MMInventoryCode",
        "type": "Text",
        "required": false,
        "maxLength": 128,
        "description": "Codigo de inventario."
      },
      {
        "displayName": "Notes",
        "internalName": "MMNotes",
        "type": "Note",
        "required": false,
        "numberOfLines": 4,
        "plainText": true,
        "description": "Observaciones tecnicas."
      }
    ],
    "indexes": [
      "MMRoomLookup",
      "MMResourceLookup",
      "MMIsOperational"
    ],
    "views": [

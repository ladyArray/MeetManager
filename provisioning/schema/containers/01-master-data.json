        "choices": [
          "Json",
          "Text",
          "Number",
          "Boolean"
        ],
        "description": "Tipo de dato esperado."
      },
      {
        "displayName": "JSON value",
        "internalName": "MMJsonValue",
        "type": "Note",
        "required": false,
        "numberOfLines": 12,
        "plainText": true,
        "description": "Valor serializado JSON."
      },
      {
        "displayName": "Text value",
        "internalName": "MMTextValue",
        "type": "Text",
        "required": false,
        "maxLength": 255,

      "enableVersioning": true,
      "majorVersions": 30,
      "enableAttachments": false
    },
    "fields": [
      {
        "displayName": "Template code",
        "internalName": "MMTemplateCode",
        "type": "Text",
        "required": true,
        "indexed": true,
        "maxLength": 64,
        "description": "Codigo funcional de plantilla."
      },
      {
        "displayName": "Description",
        "internalName": "MMDescription",
        "type": "Note",
        "required": false,
        "numberOfLines": 6,

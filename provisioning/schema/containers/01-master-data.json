        "choices": [
          "dev",
          "int",
          "pre",
          "prod"
        ],
        "description": "Entorno al que aplica la configuracion."
      },
      {
        "displayName": "Owner email",
        "internalName": "MMOwnerEmail",
        "type": "Text",
        "required": false,
        "maxLength": 255,
        "description": "Usuario propietario del ajuste."
      },
      {
        "displayName": "Accent color",
        "internalName": "MMAccentColor",
        "type": "Text",
        "required": false,
        "maxLength": 32,
        "description": "Color de apoyo para filtros o vistas guardadas."
      },
      {
        "displayName": "Saved filter JSON",
        "internalName": "MMSavedFilterJson",
        "type": "Note",
        "required": false,
        "numberOfLines": 12,
        "plainText": true,
        "description": "Filtro serializado de compatibilidad con la UI actual."
      },
      {
        "displayName": "Active",
        "internalName": "MMActive",
        "type": "Boolean",
        "required": true,
        "indexed": true,
        "defaultValue": true,
        "description": "Activa o desactiva el registro."
      }
    ],
    "indexes": [
      "MMConfigurationKey",
      "MMEnvironmentName",
      "MMActive"
    ],
    "views": [
      {
        "title": "By scope",
        "setAsDefault": true,
        "rowLimit": 100,
        "fields": [
          "Title",
          "MMConfigurationKey",
          "MMConfigurationScope",
          "MMConfigurationType",
          "MMEnvironmentName",
          "MMActive"
        ],
        "query": "<OrderBy><FieldRef Name='MMConfigurationScope' /><FieldRef Name='Title' /></OrderBy>"
      }
    ]
  }
]

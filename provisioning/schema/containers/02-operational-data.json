      "MMMeetingType",
      "MMWorkflowStatus",
      "MMRoomLookup",
      "MMLocationLookup",
      "MMHasConflicts"
    ],
    "views": [
      {
        "title": "All meetings",
        "setAsDefault": true,
        "rowLimit": 100,
        "fields": [
          "Title",
          "MMMeetingCode",
          "MMOrganizer",
          "MMStartDate",
          "MMEndDate",
          "MMMeetingType",
          "MMWorkflowStatus",
          "MMRoomLookup",
          "MMHasConflicts"
        ],
        "query": "<OrderBy><FieldRef Name='MMStartDate' Ascending='FALSE' /></OrderBy>"
      },
      {
        "title": "Upcoming meetings",
        "setAsDefault": false,
        "rowLimit": 50,
        "fields": [
          "Title",
          "MMMeetingCode",
          "MMStartDate",
          "MMEndDate",
          "MMMeetingType",
          "MMWorkflowStatus",
          "MMRoomLookup"
        ],
        "query": "<Where><Geq><FieldRef Name='MMStartDate' /><Value IncludeTimeValue='TRUE' Type='DateTime'><Today /></Value></Geq></Where><OrderBy><FieldRef Name='MMStartDate' /></OrderBy>"
      },
      {
        "title": "Conflicted meetings",
        "setAsDefault": false,
        "rowLimit": 50,
        "fields": [
          "Title",
          "MMMeetingCode",
          "MMStartDate",
          "MMEndDate",
          "MMOrganizer",
          "MMRoomLookup",
          "MMConflictSummary"
        ],
        "query": "<Where><Eq><FieldRef Name='MMHasConflicts' /><Value Type='Boolean'>1</Value></Eq></Where><OrderBy><FieldRef Name='MMStartDate' /></OrderBy>"
      }
    ]

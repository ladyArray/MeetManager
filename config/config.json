{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "meet-manager-dashboard-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/meetManagerDashboard/MeetManagerDashboardWebPart.js",
          "manifest": "./src/webparts/meetManagerDashboard/MeetManagerDashboardWebPart.manifest.json"
        }
      ]
    },
    "teams-meetings-panel-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/teamsMeetingsPanel/TeamsMeetingsPanelWebPart.js",
          "manifest": "./src/webparts/teamsMeetingsPanel/TeamsMeetingsPanelWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "MeetManagerDashboardWebPartStrings": "lib/webparts/meetManagerDashboard/loc/{locale}.js",
    "TeamsMeetingsPanelWebPartStrings": "lib/webparts/teamsMeetingsPanel/loc/{locale}.js"
  }
}
